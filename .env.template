# DistributeX Worker Environment Configuration
# Copy this to .env and fill in your values

# Required: Your authentication token (from signup)
AUTH_TOKEN=your_auth_token_here

# Required: Your worker ID (from signup)
WORKER_ID=your_worker_id_here

# Optional: Custom node name (defaults to hostname)
NODE_NAME=my-docker-worker

# Optional: API URL (defaults to production)
DISTRIBUTEX_API_URL=https://distributex-api.distributex.workers.dev

# Optional: Coordinator WebSocket URL (defaults to production)
DISTRIBUTEX_COORDINATOR_URL=wss://distributex-coordinator.distributex.workers.dev/ws

# Optional: Resource limits (leave empty for auto-detect)
MAX_CPU_CORES=
MAX_MEMORY_GB=
MAX_STORAGE_GB=

# Optional: GPU support (true/false, defaults to auto-detect)
ENABLE_GPU=true

# Optional: GPU type (nvidia/amd/intel, defaults to auto-detect)
GPU_TYPE=
